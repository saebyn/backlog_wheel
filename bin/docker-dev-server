#!/usr/bin/env bash
set -euo pipefail

if [ -f .envrc ]; then
  while IFS= read -r line; do
    case "$line" in
      export\ *) eval "$line" ;;
    esac
  done < .envrc
fi

export DATABASE_URL="ecto://postgres:postgres@postgres:5432/backlog_wheel_dev"

mix deps.get
mix ecto.create
mix ecto.migrate
mix phx.server
